# =============================================
# Simple IoT 本地一键部署配置
# 复制此文件为 .env 并修改配置
# =============================================

# PostgreSQL 配置 (Docker 容器内使用服务名作为主机名)
POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_PORT=5432
DATABASE=simple

# InfluxDB 配置 (需要单独安装)
# macOS Docker 访问本地: http://host.docker.internal:8181
# Linux Docker 访问本地: http://172.17.0.1:8181
INFLUXDB_URL=http://host.docker.internal:8181
# 通过 influxdb3 create token --admin 获取
INFLUXDB_TOKEN=iot_token_123456
INFLUXDB_DATABASE=simple

# RustFS (S3) 配置
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin123
S3_BUCKET_NAME=iot-bucket
S3_REGION=us-east-1
S3_ENDPOINT=http://rustfs:9000
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# JVM 参数 - 解决 Arrow/Netty 兼容性问题 (Java 21+ 必需)
JDK_JAVA_OPTIONS=--add-opens=java.base/java.nio=org.apache.arrow.memory.core,ALL-UNNAMED --sun-misc-unsafe-memory-access=allow

# 服务端口配置
SERVER_PORT=5010
WEB_PORT=80
MQTT_PORT=1883
MQTT_WS_PORT=8083
MQTT_HTTP_PORT=18083
