<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.dingdaoyi.mapper.EmailConfigMapper">

    <select id="findDefaultConfig" resultType="com.github.dingdaoyi.entity.EmailConfig">
        SELECT * FROM tb_email_config
        WHERE is_default = true AND status = 1
        LIMIT 1
    </select>

</mapper>
